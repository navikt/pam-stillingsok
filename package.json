{
    "name": "pam-stillingsok-frontend",
    "version": "0.211.0",
    "description": "",
    "type": "module",
    "packageManager": "pnpm@10.24.0",
    "engines": {
        "node": "24.x"
    },
    "scripts": {
        "next": "pnpm run dev",
        "start": "next start",
        "build": "NEXT_PUBLIC_SENTRY_RELEASE=$SENTRY_RELEASE next build --webpack && pnpm run sentry:sourcemaps",
        "build:no-sourcemap": "NEXT_PUBLIC_SENTRY_RELEASE=$SENTRY_RELEASE next build --webpack",
        "dev": "next dev --webpack -p 3003 | pino-pretty --messageKey=message",
        "dev:turbo": "next dev -p 3003 | pino-pretty --messageKey=message",
        "test:prepush": "vitest run --reporter=dot",
        "test": "vitest run",
        "test:watch": "vitest watch",
        "start:dependencies": "./start-docker-compose.sh",
        "start:dependencies-with-update-containers": "./update-containers.sh && ./start-docker-compose.sh",
        "start:dependencies-with-local-search": "COMPOSE_PROFILES=local-search,opensearch,kafka ./start-docker-compose.sh",
        "generate:page-info-config": "tsx scripts/generate-page-info-config.ts",
        "lint": "biome check .",
        "lint:fix": "biome check --write .",
        "format": "biome format --write .",
        "prettier": "echo 'Formatting handled by biome – see lint script'",
        "prepare": "husky",
        "pre-commit": "lint-staged",
        "compileTS": "tsc --noEmit",
        "sentry:sourcemaps": "if [ -z \"$SENTRY_RELEASE\" ]; then echo 'Skipping Sentry sourcemaps: SENTRY_RELEASE not set'; exit 0; else sentry-cli sourcemaps inject --org nav --project pam-stillingsok ./.next && sentry-cli --url https://sentry.gc.nav.no/ sourcemaps upload --org nav --project pam-stillingsok --release=\"$SENTRY_RELEASE\" ./.next; fi"
    },
    "author": "",
    "license": "ISC",
    "dependencies": {
        "@fortedigital/nextjs-cache-handler": "^3.2.0",
        "@navikt/aksel-icons": "^8.10.4",
        "@navikt/arbeidsplassen-css": "^10.0.8",
        "@navikt/arbeidsplassen-react": "^10.0.11",
        "@navikt/arbeidsplassen-theme": "^10.0.6",
        "@navikt/ds-css": "^8.10.5",
        "@navikt/ds-react": "^8.10.5",
        "@navikt/ds-tokens": "^8.10.4",
        "@navikt/fnrvalidator": "^2.2.1",
        "@navikt/next-logger": "^5.0.0",
        "@navikt/oasis": "^3.8.0",
        "@sentry/browser": "9.47.1",
        "@sentry/nextjs": "9.47.1",
        "@vercel/otel": "1.14.1",
        "date-fns": "3.6.0",
        "html-react-parser": "5.2.17",
        "isomorphic-dompurify": "3.12.0",
        "jose": "5.10.0",
        "next": "16.2.6",
        "next-logger": "^5.0.2",
        "openid-client": "5.7.1",
        "pino": "^10.3.1",
        "prom-client": "15.1.3",
        "prop-types": "^15.8.1",
        "react": "19.2.5",
        "react-dom": "19.2.5",
        "redis": "5.12.1",
        "server-only": "0.0.1",
        "sharp": "0.34.5",
        "uuid": "14.0.0",
        "zod": "4.3.6"
    },
    "overrides": {
        "jose": "5.10.0",
        "openid-client": {
            "jose": "5.10.0"
        }
    },
    "devDependencies": {
        "@axe-core/react": "4.11.3",
        "@biomejs/biome": "^2.4.15",
        "@navikt/aksel-stylelint": "^8.10.5",
        "@sentry/cli": "2.58.5",
        "@testing-library/jest-dom": "6.9.1",
        "@testing-library/react": "16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/node": "22.19.19",
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "@vitejs/plugin-react": "^4.2.1",
        "axe-core": "4.11.4",
        "husky": "9.1.7",
        "import-in-the-middle": "1.15.0",
        "jsdom": "24.1.3",
        "lint-staged": "15.5.2",
        "next-router-mock": "^0.9.13",
        "pino-pretty": "^13.1.3",
        "require-in-the-middle": "7.5.2",
        "stylelint": "16.26.1",
        "stylelint-config-recommended": "14.0.1",
        "tsx": "^4.21.0",
        "typescript": "5.9.3",
        "vitest": "3.2.4"
    },
    "dependencyNotes": {
        "import-in-the-middle": "Brukes av Sentry/OpenTelemetry for server-instrumentering. Må ligge på rot for pnpm/Next 15.",
        "require-in-the-middle": "Som over, men for CommonJS/require. Sikrer at Sentry-instrumentering fungerer."
    },
    "lint-staged": {
        "src/app/\\(artikler\\)/**/page.tsx": [
            "pnpm run generate:page-info-config",
            "git add src/app/(artikler)/pageInfoConfig.generated.ts"
        ],
        "./*/**/*.{js,jsx,ts,tsx,json}": [
            "pnpm biome check --write --no-errors-on-unmatched"
        ],
        "./*/**/*.css": [
            "pnpm stylelint --fix"
        ],
        "*.md": [
            "pnpm biome format --write --no-errors-on-unmatched"
        ]
    },
    "pnpm": {
        "overrides": {
            "@types/react": "19.2.14",
            "@types/react-dom": "19.2.3"
        }
    }
}
